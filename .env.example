# 🔐 SecureChat Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to version control

# Database Configuration (REQUIRED)
DATABASE_URL=jdbc:postgresql://your-host:5432/your-database?currentSchema=chatapp_prod&sslmode=require
DATABASE_USERNAME=your-username
DATABASE_PASSWORD=your-secure-password

# CORS Configuration (REQUIRED for production)
# Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Application Port (Optional, default: 8080)
PORT=8080

# Spring Profile (local/dev/prod)
SPRING_PROFILES_ACTIVE=prod

# Security Settings
# JWT secret for authentication (generate a strong random string)
JWT_SECRET=your-jwt-secret-minimum-256-bits

# File Upload Configuration
# S3 or compatible storage
FILE_STORAGE_TYPE=s3
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=your-bucket-name

# Redis Configuration (for session management and scaling)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password

# Monitoring & Logging
SENTRY_DSN=your-sentry-dsn
LOG_LEVEL=INFO
